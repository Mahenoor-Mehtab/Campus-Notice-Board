generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id            String   @id @default(cuid())
  title         String
  body          String
  category      String
  priority      String
  priorityOrder Int
  publishDate   DateTime
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
